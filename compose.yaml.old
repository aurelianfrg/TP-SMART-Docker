version: "3.9"  # Compose file format


services:
  web:
    image: web
    build: ./web
    ports: 
      - "8000:80"
    # network: tp-bridge
  
  db:
    image: db
    build: ./db
    ports: 
      - "5432:5432"
    # network: tp-bridge

  words:
    image: words
    build: ./words
    ports: 
      - "8080:8080"
    # network: tp-bridge


# compose creates a virtual network between every containers by default

# networks:
#   tp-bridge: 
#     driver: bridge